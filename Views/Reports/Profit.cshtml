@{
    var report = ViewBag.Report as Dictionary<string, decimal>;
    var startDate = ViewBag.StartDate as DateTime? ?? DateTime.Today.AddMonths(-1);
    var endDate = ViewBag.EndDate as DateTime? ?? DateTime.Today;
}

<div class="container-fluid">
    <h2 class="mb-4">Profit Report</h2>
    <p class="text-muted">@startDate.ToString("yyyy-MM-dd") to @endDate.ToString("yyyy-MM-dd")</p>

    <form method="get" class="row mb-4">
        <div class="col-md-3">
            <input type="date" name="startDate" class="form-control" value="@startDate.ToString("yyyy-MM-dd")">
        </div>
        <div class="col-md-3">
            <input type="date" name="endDate" class="form-control" value="@endDate.ToString("yyyy-MM-dd")">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Generate</button>
        </div>
    </form>

    @if (report != null)
    {
        <div class="row">
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h5>Total Revenue</h5>
                        <h3>Rs. @report["TotalRevenue"].ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning">
                    <div class="card-body">
                        <h5>Total Cost</h5>
                        <h3>Rs. @report["TotalCost"].ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h5>Net Profit</h5>
                        <h3>Rs. @report["Profit"].ToString("N2")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h5>Profit Margin</h5>
                        <h3>@report["ProfitMargin"].ToString("N2")%</h3>
                    </div>
                </div>
            </div>
        </div>
    }
</div>