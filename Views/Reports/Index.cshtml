@{
    ViewData["Title"] = "Reports";
}

<div class="container-fluid">
    <h2 class="mb-4">Reports</h2>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Sales Reports</h5>
                    <p class="text-muted">Daily, monthly, and custom date range sales reports</p>
                    <a asp-action="Sales" class="btn btn-primary">View Sales</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Stock Report</h5>
                    <p class="text-muted">Current inventory levels and values</p>
                    <a asp-action="Stock" class="btn btn-primary">View Stock</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Low Stock Alert</h5>
                    <p class="text-muted">Products below reorder level</p>
                    <a asp-action="LowStock" class="btn btn-warning">View Low Stock</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Best Selling Products</h5>
                    <p class="text-muted">Top performing products by quantity</p>
                    <a asp-action="BestSelling" class="btn btn-primary">View Best Sellers</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5>Profit Report</h5>
                    <p class="text-muted">Revenue, cost, and profit analysis</p>
                    <a asp-action="Profit" class="btn btn-success">View Profit</a>
                </div>
            </div>
        </div>
    </div>
</div>