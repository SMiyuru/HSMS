@model List<HSMS.Models.BestSellingProductDto>
@{
    ViewData["Title"] = "Best Selling Products";
    var startDate = ViewBag.StartDate as DateTime? ?? DateTime.Today.AddDays(-30);
    var endDate = ViewBag.EndDate as DateTime? ?? DateTime.Today;
}

<div class="container-fluid">
    <h2 class="mb-4">Best Selling Products</h2>
    <p class="text-muted">@startDate.ToString("yyyy-MM-dd") to @endDate.ToString("yyyy-MM-dd")</p>

    <form method="get" class="row mb-3">
        <div class="col-md-3">
            <input type="date" name="startDate" class="form-control" value="@startDate.ToString("yyyy-MM-dd")">
        </div>
        <div class="col-md-3">
            <input type="date" name="endDate" class="form-control" value="@endDate.ToString("yyyy-MM-dd")">
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">Generate</button>
        </div>
    </form>

    <div class="mb-3">
        <span class="text-muted">@Model.Count products</span>
    </div>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Product</th>
                <th>Category</th>
                <th>Total Quantity</th>
                <th>Total Revenue</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.CategoryName</td>
                    <td>@item.TotalQuantity</td>
                    <td>Rs. @item.TotalRevenue.ToString("N2")</td>
                </tr>
            }
        </tbody>
    </table>
</div>