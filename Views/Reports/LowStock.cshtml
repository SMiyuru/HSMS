@model List<HSMS.Models.Product>
@{
    ViewData["Title"] = "Low Stock Report";
    var pageNo = Convert.ToInt32(ViewContext.RouteData.Values["page"] ?? "1");
    var pageSize = 20;
    var totalCount = Model.Count;
    var totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
    var pagedProducts = Model.Skip((pageNo - 1) * pageSize).Take(pageSize).ToList();
}

<div class="container-fluid">
    <h2 class="mb-4">Low Stock Alert Report</h2>

    <p class="text-muted mb-3">@totalCount products below reorder level</p>

    <table class="table table-striped table-danger">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Category</th>
                <th>Current Stock</th>
                <th>Reorder Level</th>
                <th>Shortage</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in pagedProducts)
            {
                <tr>
                    <td>@product.Code</td>
                    <td>@product.Name</td>
                    <td>@product.Category?.Name</td>
                    <td class="text-danger fw-bold">@product.CurrentStock</td>
                    <td>@product.ReorderLevel</td>
                    <td class="text-danger">@(product.ReorderLevel - product.CurrentStock)</td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <nav aria-label="LowStock pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(pageNo == 1 ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("LowStock", new { page = pageNo - 1 })">Previous</a>
                </li>
                @for (int i = Math.Max(1, pageNo - 2); i <= Math.Min(totalPages, pageNo + 2); i++)
                {
                    <li class="page-item @(i == pageNo ? "active" : "")">
                        <a class="page-link" href="@Url.Action("LowStock", new { page = i })">@i</a>
                    </li>
                }
                <li class="page-item @(pageNo == totalPages ? "disabled" : "")">
                    <a class="page-link" href="@Url.Action("LowStock", new { page = pageNo + 1 })">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>