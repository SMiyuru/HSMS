@model List<HSMS.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Trail";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container-fluid">
    <h2 class="mb-4">Audit Trail</h2>

    <div class="row mb-3">
        <div class="col-md-12">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control" placeholder="Search user, action, entity..." value="@ViewBag.Search">
                </div>
                <div class="col-md-3">
                    <input type="date" name="startDate" class="form-control" value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <input type="date" name="endDate" class="form-control" value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary">Filter</button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Details</th>
                        <th>IP Address</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@log.UserName</td>
                            <td>
                                @{
                                    var badgeClass = log.Action switch
                                    {
                                        "Create" => "success",
                                        "Update" => "warning",
                                        "Delete" => "danger",
                                        "Login" => "primary",
                                        "Logout" => "danger",
                                        "Sale" => "info",
                                        "View" => "success",
                                        _ => "dark"
                                    };
                                }
                                <span class="badge bg-@badgeClass text-white">@log.Action</span>
                            </td>
                            <td>
                                @if (log.EntityId.HasValue)
                                {
                                    @log.EntityName <small>(#@log.EntityId)</small>
                                }
                                else
                                {
                                    @log.EntityName
                                }
                            </td>
                            <td><small>@log.Changes</small></td>
                            <td><small class="text-muted">@log.IpAddress</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Audit pagination">
            <ul class="pagination justify-content-center">
                @{
                    var currentPage = (int)ViewBag.CurrentPage;
                    var totalPages = (int)ViewBag.TotalPages;
                    var search = ViewBag.Search;
                    var startDate = ViewBag.StartDate?.ToString("yyyy-MM-dd");
                    var endDate = ViewBag.EndDate?.ToString("yyyy-MM-dd");
                }
                
                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1, search, startDate, endDate })">Previous</a>
                    </li>
                }
                
                @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { page = i, search, startDate, endDate })">@i</a>
                    </li>
                }
                
                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1, search, startDate, endDate })">Next</a>
                    </li>
                }
            </ul>
        </nav>
        <div class="text-center text-muted small">
            Page @currentPage of @totalPages (@ViewBag.TotalLogs total records)
        </div>
    }

    @if (Model.Count == 0)
    {
        <div class="alert alert-info mt-3">No audit records found.</div>
    }
</div>