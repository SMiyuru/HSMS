@model List<HSMS.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Trail";
}

<style>
    .audit-page {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .page-header h2 {
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: #212529;
    }

    .page-header p {
        margin-bottom: 0;
        color: #6c757d;
    }

    .panel-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .panel-body {
        padding: 1.25rem;
    }

    .filters-form .form-control {
        border-radius: 12px;
        min-height: 44px;
    }

    .filters-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .filters-actions .btn {
        min-height: 44px;
        border-radius: 12px;
        font-weight: 600;
        padding-inline: 1rem;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .table-clean {
        margin-bottom: 0;
        vertical-align: middle;
    }

    .table-clean thead th {
        font-size: 0.82rem;
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        border-bottom-width: 1px;
        white-space: nowrap;
    }

    .table-clean tbody td {
        vertical-align: middle;
        padding-top: 0.9rem;
        padding-bottom: 0.9rem;
    }

    .action-badge {
        display: inline-block;
        padding: 0.35rem 0.7rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        line-height: 1;
    }

    .action-create {
        background: #eaf7ee;
        color: #198754;
    }

    .action-update {
        background: #fff4db;
        color: #f59f00;
    }

    .action-delete,
    .action-logout {
        background: #fdeaea;
        color: #dc3545;
    }

    .action-login {
        background: #e7f1ff;
        color: #0d6efd;
    }

    .action-sale {
        background: #e7f7fb;
        color: #0dcaf0;
    }

    .action-view {
        background: #eef8f0;
        color: #2f9e44;
    }

    .action-default {
        background: #f1f3f5;
        color: #495057;
    }

    .entity-id {
        color: #6c757d;
        font-size: 0.82rem;
    }

    .log-details {
        color: #495057;
        font-size: 0.86rem;
        max-width: 360px;
        word-break: break-word;
    }

    .muted-small {
        color: #6c757d;
        font-size: 0.84rem;
    }

    .pagination-wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        margin-top: 1rem;
    }

    .pagination .page-link {
        border-radius: 10px !important;
        margin: 0 0.15rem;
        border: 1px solid #e9ecef;
        color: #495057;
    }

    .pagination .page-item.active .page-link {
        background: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
    }

    .empty-state {
        padding: 2rem 1rem;
        text-align: center;
        color: #6c757d;
    }

    .empty-state i {
        font-size: 2rem;
        margin-bottom: 0.75rem;
        color: #adb5bd;
    }

    @@media (max-width: 767.98px) {
        .panel-body {
            padding: 1rem;
        }

        .filters-actions {
            width: 100%;
        }

        .filters-actions .btn {
            flex: 1;
        }
    }
</style>

<div class="audit-page">
    <div class="page-header">
        <h2>Audit Trail</h2>
        <p>Track user activity, system actions, and record changes.</p>
    </div>

    <div class="panel-card">
        <div class="panel-body">
            <form method="get" class="row g-3 filters-form">
                <div class="col-md-3">
                    <input type="text"
                           name="search"
                           class="form-control"
                           placeholder="Search user, action, entity..."
                           value="@ViewBag.Search">
                </div>

                <div class="col-md-3">
                    <input type="date"
                           name="startDate"
                           class="form-control"
                           value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")">
                </div>

                <div class="col-md-3">
                    <input type="date"
                           name="endDate"
                           class="form-control"
                           value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")">
                </div>

                <div class="col-md-3">
                    <div class="filters-actions">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-funnel me-2"></i>Filter
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Reset
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="panel-card">
        <div class="panel-body p-0">
            @if (Model.Count > 0)
            {
                <div class="table-wrap">
                    <table class="table table-clean mb-0">
                        <thead>
                            <tr>
                                <th>Date & Time</th>
                                <th>User</th>
                                <th>Action</th>
                                <th>Entity</th>
                                <th>Details</th>
                                <th>IP Address</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                var badgeClass = log.Action switch
                                {
                                    "Create" => "action-create",
                                    "Update" => "action-update",
                                    "Delete" => "action-delete",
                                    "Login" => "action-login",
                                    "Logout" => "action-logout",
                                    "Sale" => "action-sale",
                                    "View" => "action-view",
                                    _ => "action-default"
                                };

                                <tr>
                                    <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td class="fw-semibold">@log.UserName</td>
                                    <td>
                                        <span class="action-badge @badgeClass">@log.Action</span>
                                    </td>
                                    <td>
                                        <div>@log.EntityName</div>
                                        @if (log.EntityId.HasValue)
                                        {
                                            <div class="entity-id">#@log.EntityId</div>
                                        }
                                    </td>
                                    <td>
                                        <div class="log-details">@log.Changes</div>
                                    </td>
                                    <td>
                                        <span class="muted-small">@log.IpAddress</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-clock-history d-block"></i>
                    <div class="fw-semibold mb-1">No audit records found</div>
                    <div class="small">Try changing the filters or search terms.</div>
                </div>
            }
        </div>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        var currentPage = (int)ViewBag.CurrentPage;
        var totalPages = (int)ViewBag.TotalPages;
        var search = ViewBag.Search;
        var startDate = ViewBag.StartDate?.ToString("yyyy-MM-dd");
        var endDate = ViewBag.EndDate?.ToString("yyyy-MM-dd");

        <div class="pagination-wrap">
            <nav aria-label="Audit pagination">
                <ul class="pagination mb-0">
                    @if (currentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = currentPage - 1, search, startDate, endDate })">
                                Previous
                            </a>
                        </li>
                    }

                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(totalPages, currentPage + 2); i++)
                    {
                        <li class="page-item @(i == currentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = i, search, startDate, endDate })">@i</a>
                        </li>
                    }

                    @if (currentPage < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = currentPage + 1, search, startDate, endDate })">
                                Next
                            </a>
                        </li>
                    }
                </ul>
            </nav>

            <div class="text-muted small">
                Page @currentPage of @totalPages (@ViewBag.TotalLogs total records)
            </div>
        </div>
    }
</div>