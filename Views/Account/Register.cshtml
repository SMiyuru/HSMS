@model HSMS.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="container-fluid px-0" style="height: 100vh; overflow: hidden;">
    <div class="row g-0 h-100">

        <div class="col-lg-6 d-none d-lg-flex bg-light border-end align-items-center justify-content-center h-100">
            <div style="max-width: 380px;">
                <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-primary text-white mb-3"
                     style="width: 56px; height: 56px;">
                    <i class="bi bi-shop fs-4"></i>
                </div>

                <h1 class="fw-bold mb-2">HSMS</h1>
                <p class="text-primary fw-semibold mb-2">Hardware Store Management System</p>
                <p class="text-muted mb-0">
                    Create your account and start managing your store with ease.
                </p>
            </div>
        </div>

        <div class="col-lg-6 d-flex align-items-center justify-content-center h-100 bg-white">
            <div class="w-100 px-4" style="max-width: 400px;">

                <div class="text-center mb-4 d-lg-none">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-4 bg-primary text-white mb-2"
                         style="width: 52px; height: 52px;">
                        <i class="bi bi-shop fs-5"></i>
                    </div>
                    <h3 class="fw-bold mb-1">HSMS</h3>
                    <p class="text-muted small mb-0">Hardware Store Management System</p>
                </div>

                <div class="mb-4 text-center text-lg-start">
                    <h2 class="fw-bold mb-1">Create account</h2>
                    <p class="text-muted mb-0">Get started with HSMS.</p>
                </div>

                <form asp-action="Register" method="post" class="card border-0 shadow-lg rounded-4 p-4">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Enter your full name">
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="Enter your email">
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Password</label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Create a password">
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Enter your address"></textarea>
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Register
                    </button>

                    <div class="text-center mt-3">
                        <span class="text-muted small">Already have an account?</span>
                        <a asp-controller="Account" asp-action="Login" class="fw-semibold text-decoration-none ms-1">
                            Login
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>