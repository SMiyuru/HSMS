@model IEnumerable<HSMS.Models.Product>
@{
    ViewData["Title"] = "Counter POS";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-7">
            <div class="card">
                <div class="card-header">
                    <h5>Products</h5>
                </div>
                <div class="card-body">
                    <input type="text" id="searchProduct" class="form-control mb-3" placeholder="Search products...">
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-sm table-hover" id="productsTable">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody id="productsList">
                                @foreach (var product in Model)
                                {
                                    <tr>
                                        <td>@product.Code</td>
                                        <td>@product.Name</td>
                                        <td>Rs. @product.SellingPrice.ToString("N2")</td>
                                        <td>@product.CurrentStock</td>
                                        <td>
                                            <button class="btn btn-sm btn-primary add-to-cart" 
                                                    data-id="@product.Id" 
                                                    data-name="@product.Name" 
                                                    data-price="@product.SellingPrice"
                                                    data-stock="@product.CurrentStock">
                                                Add
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card">
                <div class="card-header">
                    <h5>Cart</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm" id="cartTable">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Qty</th>
                                <th>Price</th>
                                <th>Total</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="cartItems">
                        </tbody>
                    </table>
                    
                    <div class="mt-3">
                        <div class="d-flex justify-content-between">
                            <span>Subtotal:</span>
                            <span id="subtotal">Rs. 0.00</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Discount (%):</span>
                            <input type="number" id="discountPercent" class="form-control form-control-sm w-25" value="0" min="0" max="100" placeholder="0">
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Discount Amount:</span>
                            <span id="discountAmount">Rs. 0.00</span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold border-top pt-2">
                            <span>Total:</span>
                            <span id="total">Rs. 0.00</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span>Cash Received:</span>
                            <input type="number" id="cashReceived" class="form-control form-control-sm w-50" value="0" min="0" step="0.01">
                        </div>
                        <div class="d-flex justify-content-between text-success fw-bold">
                            <span>Balance:</span>
                            <span id="balance">Rs. 0.00</span>
                        </div>
                    </div>

                    <div class="mt-3">
                        <button id="completeSale" class="btn btn-success w-100">Complete Sale</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
let cart = [];

document.getElementById('searchProduct').addEventListener('input', function() {
    const search = this.value.toLowerCase();
    const rows = document.querySelectorAll('#productsList tr');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(search) ? '' : 'none';
    });
});

document.querySelectorAll('.add-to-cart').forEach(btn => {
    btn.addEventListener('click', function() {
        const id = this.dataset.id;
        const name = this.dataset.name;
        const price = parseFloat(this.dataset.price);
        const stock = parseInt(this.dataset.stock);
        
        const existing = cart.find(item => item.id === id);
        if (existing) {
            if (existing.qty < stock) {
                existing.qty++;
            }
        } else {
            cart.push({ id, name, price, qty: 1 });
        }
        renderCart();
    });
});

function renderCart() {
    const tbody = document.getElementById('cartItems');
    tbody.innerHTML = '';
    let subtotal = 0;
    
    cart.forEach((item, index) => {
        const itemTotal = item.price * item.qty;
        subtotal += itemTotal;
        tbody.innerHTML += `
            <tr>
                <td>${item.name}</td>
                <td>
                    <input type="number" class="form-control form-control-sm" 
                           value="${item.qty}" min="1" style="width: 60px;"
                           onchange="updateQty(${index}, this.value)">
                </td>
                <td>Rs. ${item.price.toFixed(2)}</td>
                <td>Rs. ${itemTotal.toFixed(2)}</td>
                <td>
                    <button class="btn btn-sm btn-danger" onclick="removeFromCart(${index})">X</button>
                </td>
            </tr>
        `;
    });
    
    const discountPercent = parseFloat(document.getElementById('discountPercent').value) || 0;
    const discountAmount = subtotal * (discountPercent / 100);
    const total = subtotal - discountAmount;
    const cashReceived = parseFloat(document.getElementById('cashReceived').value) || 0;
    const balance = cashReceived - total;
    
    document.getElementById('subtotal').textContent = 'Rs. ' + subtotal.toFixed(2);
    document.getElementById('discountAmount').textContent = 'Rs. ' + discountAmount.toFixed(2);
    document.getElementById('total').textContent = 'Rs. ' + total.toFixed(2);
    document.getElementById('balance').textContent = 'Rs. ' + balance.toFixed(2);
    
    if (balance < 0) {
        document.getElementById('balance').classList.remove('text-success');
        document.getElementById('balance').classList.add('text-danger');
    } else {
        document.getElementById('balance').classList.remove('text-danger');
        document.getElementById('balance').classList.add('text-success');
    }
}

function updateQty(index, qty) {
    cart[index].qty = parseInt(qty);
    renderCart();
}

function removeFromCart(index) {
    cart.splice(index, 1);
    renderCart();
}

document.getElementById('discountPercent').addEventListener('input', renderCart);
document.getElementById('cashReceived').addEventListener('input', renderCart);

document.getElementById('completeSale').addEventListener('click', function() {
    if (cart.length === 0) {
        alert('Cart is empty!');
        return;
    }
    
    const subtotal = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
    const discountPercent = parseFloat(document.getElementById('discountPercent').value) || 0;
    const discountAmount = subtotal * (discountPercent / 100);
    const total = subtotal - discountAmount;
    const cashReceived = parseFloat(document.getElementById('cashReceived').value) || 0;
    
    if (cashReceived < total) {
        alert('Insufficient cash received!');
        return;
    }
    
    const order = {
        OrderItems: cart.map(item => ({ ProductId: item.id, Quantity: item.qty })),
        Discount: discountAmount,
        TaxAmount: 0,
        PaymentMethod: 0
    };
    
    fetch('@Url.Action("CreateCounterOrder", "Sales")', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(order)
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            alert('Sale completed! Order: ' + data.orderNumber + '\nBalance: Rs. ' + (cashReceived - total).toFixed(2));
            cart = [];
            document.getElementById('discountPercent').value = 0;
            document.getElementById('cashReceived').value = 0;
            renderCart();
            window.location.href = '/Sales/Invoice/' + data.orderId;
        } else {
            alert(data.message);
        }
    });
});
</script>