@model IEnumerable<HSMS.Models.Product>
@{
    ViewData["Title"] = "Counter POS";
}

<style>
    .pos-page {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .panel-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .panel-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #eef1f4;
        font-weight: 700;
    }

    .panel-body {
        padding: 1.25rem;
    }

    .search-input {
        border-radius: 12px;
        height: 42px;
    }

    .table-clean th {
        font-size: 0.8rem;
        color: #6c757d;
        text-transform: uppercase;
        border-bottom: 1px solid #eee;
    }

    .table-clean td {
        vertical-align: middle;
    }

    .btn-soft {
        border-radius: 10px;
        padding: 0.35rem 0.7rem;
        font-size: 0.85rem;
    }

    .cart-summary div {
        margin-bottom: 6px;
    }

    .cart-total {
        font-size: 1.1rem;
    }
</style>

<div class="pos-page">

    <div class="row g-4">

        <!-- PRODUCTS -->
        <div class="col-lg-7">
            <div class="panel-card">
                <div class="panel-header">
                    Products
                </div>

                <div class="panel-body">

                    <input type="text" id="searchProduct"
                           class="form-control search-input mb-3"
                           placeholder="Search products...">

                    <div style="max-height: 420px; overflow-y: auto;">
                        <table class="table table-clean table-hover">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="productsList">
                                @foreach (var product in Model)
                                {
                                    <tr>
                                        <td>@product.Code</td>
                                        <td>@product.Name</td>
                                        <td>Rs. @product.SellingPrice.ToString("N2")</td>
                                        <td>@product.CurrentStock</td>
                                        <td>
                                            <button class="btn btn-primary btn-soft add-to-cart"
                                                    data-id="@product.Id"
                                                    data-name="@product.Name"
                                                    data-price="@product.SellingPrice"
                                                    data-stock="@product.CurrentStock">
                                                Add
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

        <!-- CART -->
        <div class="col-lg-5">
            <div class="panel-card">
                <div class="panel-header">
                    Cart
                </div>

                <div class="panel-body">

                    <div style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-clean">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Qty</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="cartItems"></tbody>
                        </table>
                    </div>

                    <div class="cart-summary mt-3 small">

                        <div class="d-flex justify-content-between">
                            <span>Subtotal</span>
                            <span id="subtotal">Rs. 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span>Discount</span>
                            <input type="number" id="discountPercent"
                                   class="form-control form-control-sm w-25"
                                   value="0">
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Discount Amount</span>
                            <span id="discountAmount">Rs. 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between fw-bold border-top pt-2 cart-total">
                            <span>Total</span>
                            <span id="total">Rs. 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span>Cash</span>
                            <input type="number" id="cashReceived"
                                   class="form-control form-control-sm w-50"
                                   value="0">
                        </div>

                        <div class="d-flex justify-content-between fw-bold">
                            <span>Balance</span>
                            <span id="balance">Rs. 0.00</span>
                        </div>

                    </div>

                    <button id="completeSale" class="btn btn-success w-100 mt-3">
                        Complete Sale
                    </button>

                </div>
            </div>
        </div>

    </div>

</div>