@model IEnumerable<HSMS.Models.Product>
@{
    ViewData["Title"] = "Counter POS";
}

<style>
    .pos-page {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .panel-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 18px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .panel-header {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #eef1f4;
        font-weight: 700;
    }

    .panel-body {
        padding: 1.25rem;
    }

    .search-input {
        border-radius: 12px;
        height: 42px;
    }

    .table-clean th {
        font-size: 0.8rem;
        color: #6c757d;
        text-transform: uppercase;
        border-bottom: 1px solid #eee;
    }

    .table-clean td {
        vertical-align: middle;
    }

    .btn-soft {
        border-radius: 10px;
        padding: 0.35rem 0.7rem;
        font-size: 0.85rem;
    }

    .cart-summary div {
        margin-bottom: 6px;
    }

    .cart-total {
        font-size: 1.1rem;
    }
</style>

<div class="pos-page">

    <div class="row g-4">

        <!-- PRODUCTS -->
        <div class="col-lg-7">
            <div class="panel-card">
                <div class="panel-header">
                    Products
                </div>

                <div class="panel-body">

                    <input type="text" id="searchProduct"
                           class="form-control search-input mb-3"
                           placeholder="Search products...">

                    <div style="max-height: 420px; overflow-y: auto;">
                        <table class="table table-clean table-hover">
                            <thead>
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th>Price</th>
                                    <th>Stock</th>
                                    <th>Reorder Level</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="productsList">
                                @foreach (var product in Model)
                                {
                                    <tr>
                                        <td>@product.Code</td>
                                        <td>@product.Name</td>
                                        <td>Rs. @product.SellingPrice.ToString("N2")</td>
                                        <td>@product.CurrentStock</td>
                                        <td>@product.ReorderLevel</td>
                                        <td>
                                            <button class="btn btn-primary btn-soft add-to-cart"
                                                    onclick="addToCart(@product.Id, '@product.Name.Replace("'", "\\'")', @product.SellingPrice, @product.CurrentStock)">
                                                Add
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>

        <!-- CART -->
        <div class="col-lg-5">
            <div class="panel-card mb-3">
                <div class="panel-header d-flex justify-content-between align-items-center">
                    <span>Cart</span>
                    <button class="btn btn-sm btn-outline-secondary" onclick="showRecallModal()">
                        <i class="bi bi-file-earmark-text"></i> Recall
                    </button>
                </div>

                <div class="panel-body">

                    <div style="max-height: 300px; overflow-y: auto;">
                        <table class="table table-clean" id="cartTable" style="display: none;">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Qty</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="cartItems"></tbody>
                        </table>
                        <div id="emptyCartMsg" class="text-center text-muted py-4">
                            <i class="bi bi-cart fs-1"></i>
                            <p class="mt-2">Cart is empty</p>
                        </div>
                    </div>

                    <div class="cart-summary mt-3 small">

                        <div class="d-flex justify-content-between">
                            <span>Subtotal</span>
                            <span id="subtotal">Rs. 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span>Discount</span>
                            <input type="number" id="discountPercent"
                                   class="form-control form-control-sm w-25"
                                   placeholder="0">
                        </div>

                        <div class="d-flex justify-content-between">
                            <span>Discount Amount</span>
                            <span id="discountAmount">Rs. 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between fw-bold border-top pt-2 cart-total">
                            <span>Total</span>
                            <span id="total">Rs. 0.00</span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span>Cash</span>
                            <input type="number" id="cashReceived"
                                   class="form-control form-control-sm w-50"
                                   placeholder="0">
                        </div>

                        <div class="d-flex justify-content-between fw-bold">
                            <span>Balance</span>
                            <span id="balance">Rs. 0.00</span>
                        </div>

                    </div>

                    <button id="completeSale" class="btn btn-secondary w-100 mt-3" disabled>
                        Complete Sale
                    </button>

                </div>
            </div>
        </div>

    </div>

</div>

<!-- Recall Invoice Modal -->
<div class="modal fade" id="recallModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Recall Invoice</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Invoice Number</label>
                    <input type="text" id="recallInvoiceNo" class="form-control" placeholder="e.g., ORD20260423-0001">
                </div>
                <div id="recallResult"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="recallInvoice()">Recall</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = [];
        
        function renderCart() {
            const tbody = document.getElementById('cartItems');
            const table = document.getElementById('cartTable');
            const emptyMsg = document.getElementById('emptyCartMsg');
            tbody.innerHTML = '';
            
            if (cart.length === 0) {
                table.style.display = 'none';
                emptyMsg.style.display = 'block';
                updateTotals();
                checkCash();
                return;
            }
            
            table.style.display = 'table';
            emptyMsg.style.display = 'none';
            
            cart.forEach((item, index) => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${item.name}</td>
                    <td>
                        <input type="number" class="form-control form-control-sm" style="width:60px" 
                               value="${item.qty}" min="1" max="${item.stock}"
                               onchange="updateQty(${index}, this.value)">
                    </td>
                    <td>Rs. ${(item.price * item.qty).toFixed(2)}</td>
                    <td>
                        <button class="btn btn-sm text-danger" onclick="removeFromCart(${index})">
                            <i class="bi bi-trash"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
            
            updateTotals();
        }
        
        function updateTotals() {
            let subtotal = 0;
            cart.forEach(item => { subtotal += item.price * item.qty; });
            
            const discountInput = document.getElementById('discountPercent').value;
            const discountPercent = discountInput === '' ? 0 : parseFloat(discountInput);
            const discountAmount = subtotal * (discountPercent / 100);
            const total = subtotal - discountAmount;
            
            const cashInput = document.getElementById('cashReceived').value;
            const cash = cashInput === '' ? 0 : parseFloat(cashInput);
            const balance = cash - total;
            
            document.getElementById('subtotal').textContent = 'Rs. ' + subtotal.toFixed(2);
            document.getElementById('discountAmount').textContent = 'Rs. ' + discountAmount.toFixed(2);
            document.getElementById('total').textContent = 'Rs. ' + total.toFixed(2);
            document.getElementById('balance').textContent = 'Rs. ' + balance.toFixed(2);
        }
        
        function addToCart(id, name, price, stock) {
            console.log('Adding to cart:', id, name, price, stock);
            const existing = cart.find(item => item.id === id);
            if (existing) {
                if (existing.qty < stock) {
                    existing.qty++;
                } else {
                    notyf.error('No more stock available');
                    return;
                }
            } else {
                cart.push({ id: id, name: name, price: price, stock: stock, qty: 1 });
            }
            renderCart();
            checkCash();
            notyf.success('Added to cart');
        }
        
        function updateQty(index, qty) {
            qty = parseInt(qty);
            if (qty < 1) qty = 1;
            if (qty > cart[index].stock) {
                notyf.error('Stock not available');
                qty = cart[index].stock;
            }
            cart[index].qty = qty;
            renderCart();
            checkCash();
        }
        
        function removeFromCart(index) {
            cart.splice(index, 1);
            renderCart();
            checkCash();
        }
        
        document.getElementById('discountPercent').addEventListener('input', function() {
            updateTotals();
            checkCash();
        });
        document.getElementById('cashReceived').addEventListener('input', function() {
            updateTotals();
            checkCash();
        });
        
        document.getElementById('searchProduct').addEventListener('input', function() {
            const term = this.value.toLowerCase();
            document.querySelectorAll('#productsList tr').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(term) ? '' : 'none';
            });
        });
        
        document.getElementById('completeSale').addEventListener('click', function() {
            if (cart.length === 0) {
                notyf.error('Cart is empty');
                return;
            }
            
            const cashInput = document.getElementById('cashReceived').value;
            const cash = cashInput === '' ? 0 : parseFloat(cashInput);
            const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
            const discountInput = document.getElementById('discountPercent').value;
            const discountPercent = discountInput === '' ? 0 : parseFloat(discountInput);
            const finalTotal = total - (total * discountPercent / 100);
            
            if (cash < finalTotal) {
                notyf.error('Insufficient cash');
                return;
            }
            
            const formData = new URLSearchParams();
            formData.append('OrderType', 'Counter');
            formData.append('FinalAmount', finalTotal);
            formData.append('Discount', '0');
            formData.append('TaxAmount', '0');
            
            cart.forEach((item, index) => {
                formData.append(`OrderItems[${index}].ProductId`, item.id);
                formData.append(`OrderItems[${index}].Quantity`, item.qty);
                formData.append(`OrderItems[${index}].UnitPrice`, item.price);
                formData.append(`OrderItems[${index}].TotalPrice`, item.price * item.qty);
            });
            
            fetch('@Url.Action("CreateCounterOrder", "Sales")', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: formData.toString()
            })
            .then(res => res.json())
            .then(data => {
                console.log('Response:', data);
                if (data.success) {
                    notyf.success('Sale completed!');
                    cart = [];
                    renderCart();
                    window.location.href = '/Sales/Invoice/' + data.orderId;
                } else {
                    notyf.error(data.message || 'Error completing sale');
                }
            })
            .catch(err => {
                notyf.error('Error: ' + err.message);
            });
        });
        
        function showRecallModal() {
            var modal = new bootstrap.Modal(document.getElementById('recallModal'));
            modal.show();
        }
        
        function recallInvoice() {
            const invoiceNo = document.getElementById('recallInvoiceNo').value.trim();
            if (!invoiceNo) {
                notyf.error('Please enter invoice number');
                return;
            }
            
            const formData = new URLSearchParams();
            formData.append('orderNumber', invoiceNo);
            
            fetch('@Url.Action("GetInvoiceByNumber", "Sales")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: formData.toString()
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    window.location.href = '/Sales/Invoice/' + data.orderId;
                } else {
                    notyf.error(data.message || 'Invoice not found');
                }
            })
            .catch(err => {
                notyf.error('Error: ' + err.message);
            });
        }
        
        function checkCash() {
            const btn = document.getElementById('completeSale');
            const cashInput = document.getElementById('cashReceived').value;
            const cash = cashInput === '' ? 0 : parseFloat(cashInput);
            const total = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
            const discountInput = document.getElementById('discountPercent').value;
            const discountPercent = discountInput === '' ? 0 : parseFloat(discountInput);
            const finalTotal = total - (total * discountPercent / 100);
            
            if (cart.length === 0) {
                btn.disabled = true;
                btn.classList.add('btn-secondary');
                btn.classList.remove('btn-success');
            } else if (cash < finalTotal) {
                btn.disabled = true;
                btn.classList.add('btn-secondary');
                btn.classList.remove('btn-success');
            } else {
                btn.disabled = false;
                btn.classList.remove('btn-secondary');
                btn.classList.add('btn-success');
            }
        }
        
        checkCash();
    </script>
}