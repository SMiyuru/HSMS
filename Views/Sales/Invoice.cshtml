@model HSMS.Models.Order
@{
    ViewData["Title"] = "Invoice";
    Layout = null;
    var orderDate = Model.CreatedAt.ToString("yyyy-MM-dd HH:mm");
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
body { margin: 0; padding: 15px; font-family: system-ui, sans-serif; }
@@media print {
    body { margin: 0; padding: 0; }
    .no-print { display: none !important; }
    .container { max-width: 100% !important; padding: 5mm !important; margin: 0 !important; }
    .card { border: none !important; box-shadow: none !important; margin: 0 !important; }
    .table { font-size: 11px; margin-bottom: 10px; }
}
</style>

<div class="container no-print" style="max-width: 800px;">
    <button onclick="window.print()" class="btn btn-primary mb-3">Print Invoice</button>
    <a asp-controller="Sales" asp-action="Counter" class="btn btn-secondary mb-3">New Sale</a>
</div>

<div class="container" style="max-width: 100%;">
    <div class="card" style="max-width: 700px; margin: 0 auto;">
        <div class="card-header" style="background: #f8f9fa; padding: 10px;">
            <div class="row">
                <div class="col-md-6">
                    <h4 class="mb-1">INVOICE</h4>
                    <p class="mb-0 text-muted">Hardware Store Management System</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="mb-1"><strong>Invoice #:</strong> @Model.OrderNumber</p>
                    <p class="mb-0"><strong>Date:</strong> @orderDate</p>
                </div>
            </div>
        </div>
        
        <div class="card-body p-3">
            <table class="table table-bordered table-sm">
                <thead>
                    <tr style="background: #f8f9fa;">
                        <th>Item</th>
                        <th class="text-end">Qty</th>
                        <th class="text-end">Unit Price</th>
                        <th class="text-end">Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OrderItems)
                    {
                        <tr>
                            <td>@item.Product?.Name</td>
                            <td class="text-end">@item.Quantity</td>
                            <td class="text-end">Rs. @item.UnitPrice.ToString("N2")</td>
                            <td class="text-end">Rs. @item.TotalPrice.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end">Subtotal:</td>
                        <td class="text-end">Rs. @Model.TotalAmount.ToString("N2")</td>
                    </tr>
                    @if (Model.Discount > 0)
                    {
                        <tr>
                            <td colspan="3" class="text-end">Discount:</td>
                            <td class="text-end">-Rs. @Model.Discount.ToString("N2")</td>
                        </tr>
                    }
                    <tr class="fw-bold">
                        <td colspan="3" class="text-end">TOTAL:</td>
                        <td class="text-end">Rs. @Model.FinalAmount.ToString("N2")</td>
                    </tr>
                </tfoot>
            </table>
            
            <div class="row mt-3">
                <div class="col-md-6">
                    <p class="mb-1"><strong>Payment:</strong> @Model.PaymentMethod</p>
                    <p class="mb-0"><strong>Status:</strong> @Model.Status</p>
                </div>
                <div class="col-md-6 text-end">
                    <p class="mb-0"><strong>Served by:</strong> @Model.Staff?.FullName</p>
                </div>
            </div>
        </div>
    </div>
</div>