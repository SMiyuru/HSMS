@model HSMS.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<style>
    .details-page {
        max-width: 680px;
        margin: 0 auto;
    }

    .panel-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .panel-body {
        padding: 1.5rem;
    }

    .details-title {
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .details-subtitle {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 1.25rem;
    }

    .product-image-wrap {
        display: flex;
        justify-content: center;
        margin-bottom: 1.5rem;
    }

    .product-image {
        width: 200px;
        height: 200px;
        object-fit: cover;
        border-radius: 18px;
        border: 1px solid #e9ecef;
        background: #fff;
    }

    .product-image-placeholder {
        width: 200px;
        height: 200px;
        border-radius: 18px;
        border: 1px solid #e9ecef;
        background: #f8f9fa;
        color: #adb5bd;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
    }

    .info-table {
        margin-bottom: 0;
    }

    .info-table th {
        width: 40%;
        color: #6c757d;
        font-weight: 600;
        padding: 0.75rem 0;
        border: 0;
    }

    .info-table td {
        padding: 0.75rem 0;
        border: 0;
        font-weight: 500;
    }

    .stock-badge {
        display: inline-block;
        min-width: 44px;
        text-align: center;
        padding: 0.32rem 0.58rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        background: #eef2f6;
        color: #495057;
    }

    .stock-badge.low {
        background: #fdeaea;
        color: #dc3545;
    }

    .details-actions {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }

    .details-actions .btn {
        border-radius: 12px;
        padding: 0.55rem 1rem;
        font-weight: 600;
    }
</style>

<div class="details-page">
    <div class="panel-card">
        <div class="panel-body">

            <h4 class="details-title">Product Details</h4>
            <p class="details-subtitle">View product information, pricing, stock, and supplier details.</p>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="product-image-wrap">
                    <img src="@Url.Content(Model.ImageUrl)" alt="@Model.Name" class="product-image" />
                </div>
            }
            else
            {
                <div class="product-image-wrap">
                    <div class="product-image-placeholder">
                        <i class="bi bi-image fs-1"></i>
                        <span class="small">No image</span>
                    </div>
                </div>
            }

            @{
                var isLowStock = Model.CurrentStock <= Model.ReorderLevel;
            }

            <table class="table info-table">
                <tr>
                    <th>Code</th>
                    <td>@Model.Code</td>
                </tr>
                <tr>
                    <th>Name</th>
                    <td>@Model.Name</td>
                </tr>
                <tr>
                    <th>Category</th>
                    <td>@Model.Category?.Name</td>
                </tr>
                <tr>
                    <th>Purchase Price</th>
                    <td>Rs. @Model.PurchasePrice.ToString("N2")</td>
                </tr>
                <tr>
                    <th>Selling Price</th>
                    <td>Rs. @Model.SellingPrice.ToString("N2")</td>
                </tr>
                <tr>
                    <th>Current Stock</th>
                    <td>
                        <span class="stock-badge @(isLowStock ? "low" : "")">
                            @Model.CurrentStock
                        </span>
                    </td>
                </tr>
                <tr>
                    <th>Reorder Level</th>
                    <td>@Model.ReorderLevel</td>
                </tr>
                <tr>
                    <th>Supplier</th>
                    <td>@Model.Supplier?.Name</td>
                </tr>
            </table>

            <div class="details-actions">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    Back to List
                </a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit Product
                </a>
            </div>

        </div>
    </div>
</div>