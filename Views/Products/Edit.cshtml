@model HSMS.Models.Product
@{
    ViewData["Title"] = "Edit Product";
}

<style>
    .edit-page {
        max-width: 620px;
        margin: 0 auto;
    }

    .panel-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .panel-body {
        padding: 1.5rem;
    }

    .edit-title {
        font-weight: 700;
        margin-bottom: 0.25rem;
    }

    .edit-subtitle {
        color: #6c757d;
        font-size: 0.9rem;
        margin-bottom: 1.25rem;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.9rem;
    }

    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 42px;
    }

    .form-actions {
        margin-top: 1.5rem;
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
    }

    .form-actions .btn {
        border-radius: 12px;
        padding: 0.55rem 1rem;
        font-weight: 600;
    }
</style>

<div class="edit-page">
    <div class="panel-card">
        <div class="panel-body">

            <!-- Header -->
            <h4 class="edit-title">Edit Product</h4>
            <p class="edit-subtitle">Update product details and inventory settings.</p>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row g-3">

                    <div class="col-md-6">
                        <label class="form-label">Product Code</label>
                        <input asp-for="Code" class="form-control" required>
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Product Name</label>
                        <input asp-for="Name" class="form-control" required>
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Supplier</label>
                        <select asp-for="SupplierId" class="form-select" asp-items="ViewBag.SupplierId"></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Purchase Price (Rs.)</label>
                        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Selling Price (Rs.)</label>
                        <input asp-for="SellingPrice" class="form-control" type="number" step="0.01" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Current Stock</label>
                        <input asp-for="CurrentStock" class="form-control" type="number" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Reorder Level</label>
                        <input asp-for="ReorderLevel" class="form-control" type="number" required>
                    </div>

                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        Cancel
                    </a>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-1"></i>
                        Save Changes
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>