@model IEnumerable<HSMS.Models.Product>
@{
    ViewData["Title"] = "Products";

    var pageNo = 1;
    if (!string.IsNullOrEmpty(Context.Request.Query["page"]))
    {
        int.TryParse(Context.Request.Query["page"], out pageNo);
        if (pageNo < 1) pageNo = 1;
    }

    var pageSize = 20;
    var totalCount = Model.Count();
    var totalPages = (int)Math.Ceiling(totalCount / (double)pageSize);
    var pagedProducts = Model.Skip((pageNo - 1) * pageSize).Take(pageSize).ToList();
}

<style>
    .products-page {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .page-header h2 {
        font-weight: 700;
        margin-bottom: 0.25rem;
        color: #212529;
    }

    .page-header p {
        margin-bottom: 0;
        color: #6c757d;
    }

    .panel-card {
        background: #fff;
        border: 1px solid #e9ecef;
        border-radius: 20px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
    }

    .panel-body {
        padding: 1.25rem;
    }

    .toolbar {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
        align-items: center;
    }

    .search-form {
        display: flex;
        gap: 0.75rem;
        flex: 1;
        min-width: 280px;
    }

    .search-input {
        border-radius: 12px;
        min-height: 44px;
    }

    .toolbar-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .toolbar .btn {
        border-radius: 12px;
        min-height: 44px;
        padding-inline: 1rem;
        font-weight: 600;
    }

    .products-meta {
        color: #6c757d;
        font-size: 0.92rem;
    }

    .table-wrap {
        overflow-x: auto;
    }

    .table-clean {
        margin-bottom: 0;
        vertical-align: middle;
    }

    .table-clean thead th {
        font-size: 0.82rem;
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        border-bottom-width: 1px;
        white-space: nowrap;
    }

    .table-clean tbody td {
        vertical-align: middle;
        padding-top: 0.9rem;
        padding-bottom: 0.9rem;
    }

    .product-row.is-low-stock {
        background: #fff8f8;
    }

    .product-thumb {
        width: 42px;
        height: 42px;
        object-fit: cover;
        border-radius: 12px;
        border: 1px solid #e9ecef;
    }

    .product-thumb-placeholder {
        width: 42px;
        height: 42px;
        border-radius: 12px;
        background: #f1f3f5;
        color: #adb5bd;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e9ecef;
    }

    .stock-badge {
        display: inline-block;
        min-width: 44px;
        text-align: center;
        padding: 0.32rem 0.58rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        background: #eef2f6;
        color: #495057;
    }

    .stock-badge.low {
        background: #fdeaea;
        color: #dc3545;
    }

    .action-group {
        display: flex;
        gap: 0.45rem;
        flex-wrap: wrap;
    }

    .action-group .btn {
        border-radius: 10px;
        font-size: 0.82rem;
        padding: 0.4rem 0.7rem;
    }

    .pagination-wrap {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.75rem;
        margin-top: 1.25rem;
        flex-wrap: wrap;
    }

    .pagination-info {
        color: #6c757d;
        font-size: 0.9rem;
        white-space: nowrap;
    }

    .pagination {
        margin-bottom: 0;
    }

    .pagination .page-link {
        border-radius: 10px !important;
        margin: 0 0.12rem;
        border: 1px solid #e9ecef;
        color: #495057;
        min-width: 40px;
        text-align: center;
        transition: all 0.2s ease;
    }

    .pagination .page-link:hover {
        background: #f8f9fa;
        border-color: #d0d7de;
        color: #212529;
    }

    .pagination .page-item.active .page-link {
        background: #0d6efd;
        border-color: #0d6efd;
        color: #fff;
        box-shadow: 0 4px 12px rgba(13, 110, 253, 0.18);
    }

    .pagination .page-item.disabled .page-link {
        background: #f8f9fa;
        color: #adb5bd;
        border-color: #e9ecef;
    }
    
    @@media (max-width: 767.98px) {
        .panel-body {
            padding: 1rem;
        }

        .search-form {
            flex-direction: column;
        }

        .toolbar-actions {
            width: 100%;
        }

        .toolbar-actions .btn {
            flex: 1;
        }

        .pagination-wrap {
            justify-content: center;
        }

        .pagination-info {
            width: 100%;
            text-align: center;
        }
    }
</style>

<div class="products-page">
    <div class="page-header">
        <h2>Products</h2>
        <p>Manage your inventory, pricing, stock levels, and product details.</p>
    </div>

    <div class="panel-card">
        <div class="panel-body">
            <div class="toolbar mb-3">
                <form asp-action="Index" method="get" class="search-form">
                    <input type="text"
                           name="search"
                           class="form-control search-input"
                           placeholder="Search by name, code, or category..."
                           value="@ViewBag.Search" />

                    <div class="toolbar-actions">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search me-2"></i>Search
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Reset
                        </a>
                    </div>
                </form>

                <div class="toolbar-actions">
                    <button class="btn btn-success" onclick="openCreateModal()">
                        <i class="bi bi-plus-lg me-2"></i>Add Product
                    </button>
                </div>
            </div>

            <div class="products-meta mb-3">
                @totalCount products found
            </div>

            @if (totalPages > 1)
            {
                <div class="pagination-wrap">
                    <nav aria-label="Products pagination">
                        <ul class="pagination mb-0">
                            <li class="page-item @(pageNo == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = pageNo - 1, search = ViewBag.Search })">
                                    Previous
                                </a>
                            </li>

                            @for (int i = Math.Max(1, pageNo - 2); i <= Math.Min(totalPages, pageNo + 2); i++)
                            {
                                <li class="page-item @(i == pageNo ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i, search = ViewBag.Search })">@i</a>
                                </li>
                            }

                            <li class="page-item @(pageNo == totalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = pageNo + 1, search = ViewBag.Search })">
                                    Next
                                </a>
                            </li>
                        </ul>
                    </nav>

                    <div class="text-muted small">
                        Page @pageNo of @totalPages
                    </div>
                </div>
            }

            <div class="table-wrap">
                <table class="table table-clean">
                    <thead>
                        <tr>
                            <th>Image</th>
                            <th>Code</th>
                            <th>Name</th>
                            <th>Category</th>
                            <th>Purchase Price</th>
                            <th>Selling Price</th>
                            <th>Stock</th>
                            <th>Reorder Level</th>
                            <th>Supplier</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in pagedProducts)
                        {
                            var isLowStock = product.CurrentStock <= product.ReorderLevel;

                            <tr class="product-row @(isLowStock ? "is-low-stock" : "")">
                                <td>
                                    @if (!string.IsNullOrEmpty(product.ImageUrl))
                                    {
                                        <img src="@Url.Content(product.ImageUrl)" alt="@product.Name" class="product-thumb" />
                                    }
                                    else
                                    {
                                        <span class="product-thumb-placeholder">
                                            <i class="bi bi-image"></i>
                                        </span>
                                    }
                                </td>
                                <td>@product.Code</td>
                                <td class="fw-semibold">@product.Name</td>
                                <td>@product.Category?.Name</td>
                                <td>Rs. @product.PurchasePrice.ToString("N2")</td>
                                <td>Rs. @product.SellingPrice.ToString("N2")</td>
                                <td>
                                    <span class="stock-badge @(isLowStock ? "low" : "")">
                                        @product.CurrentStock
                                    </span>
                                </td>
                                <td>@product.ReorderLevel</td>
                                <td>@product.Supplier?.Name</td>
                                <td>
                                    <div class="action-group">
                                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-info btn-sm">
                                            View
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-warning btn-sm">
                                            Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger btn-sm">
                                            Delete
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Create Product Modal -->
<div class="modal fade" id="createProductModal" tabindex="-1" data-bs-backdrop="static">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0 pb-0">
                <h4 class="modal-title fw-bold">Add New Product</h4>
                <button type="button" class="btn-close" onclick="closeCreateModal()"></button>
            </div>
            <div class="modal-body" id="createModalContent">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function openCreateModal() {
        var modal = new bootstrap.Modal(document.getElementById('createProductModal'));
        modal.show();
        
        fetch('@Url.Action("Create", "Products")', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(response => response.text())
        .then(html => {
            document.getElementById('createModalContent').innerHTML = html;
        })
        .catch(err => {
            document.getElementById('createModalContent').innerHTML = '<div class="text-center text-danger">Error loading form</div>';
        });
    }
    
    function closeCreateModal() {
        var modalEl = document.getElementById('createProductModal');
        var modal = bootstrap.Modal.getInstance(modalEl);
        if (modal) {
            modal.hide();
        }
        modalEl.addEventListener('hidden.bs.modal', function() {
            document.getElementById('createModalContent').innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div></div>';
        }, { once: true });
    }
</script>