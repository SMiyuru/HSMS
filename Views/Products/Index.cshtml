@model IEnumerable<HSMS.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container-fluid">
    <h2 class="mb-4">Products</h2>

    <div class="row mb-3">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="d-flex">
                <input type="text" name="search" class="form-control me-2" placeholder="Search by name, code, or category..." value="@ViewBag.Search">
                <button type="submit" class="btn btn-primary">Search</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Reset</a>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">Add New Product</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-striped">
        <thead>
            <tr>
                <th>Image</th>
                <th>Code</th>
                <th>Name</th>
                <th>Category</th>
                <th>Purchase Price</th>
                <th>Selling Price</th>
                <th>Stock</th>
                <th>Supplier</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr style="@(product.CurrentStock <= product.ReorderLevel ? "background-color: #ffe6e6;" : "")">
                    <td>
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <img src="@Url.Content(product.ImageUrl)" alt="" style="width: 40px; height: 40px; object-fit: cover;" class="img-thumbnail">
                        }
                    </td>
                    <td>@product.Code</td>
                    <td>@product.Name</td>
                    <td>@product.Category?.Name</td>
                    <td>Rs. @product.PurchasePrice.ToString("N2")</td>
                    <td>Rs. @product.SellingPrice.ToString("N2")</td>
                    <td class="@(product.CurrentStock <= product.ReorderLevel ? "text-danger fw-bold" : "")">@product.CurrentStock</td>
                    <td>@product.Supplier?.Name</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-info">View</a>
                        <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>