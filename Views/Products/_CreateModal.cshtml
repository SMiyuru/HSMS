@model HSMS.Models.Product

<form asp-action="Create" method="post" enctype="multipart/form-data" id="createProductForm">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label fw-semibold">Product Code</label>
            <input asp-for="Code" class="form-control form-control-lg" placeholder="e.g., PT001" required>
            <span asp-validation-for="Code" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">Product Name</label>
            <input asp-for="Name" class="form-control form-control-lg" placeholder="Enter product name" required>
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">Category</label>
            <select asp-for="CategoryId" class="form-select form-select-lg" asp-items="ViewBag.CategoryId"></select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">Supplier</label>
            <select asp-for="SupplierId" class="form-select form-select-lg" asp-items="ViewBag.SupplierId"></select>
            <span asp-validation-for="SupplierId" class="text-danger small"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label fw-semibold">Purchase Price (Rs.)</label>
            <input asp-for="PurchasePrice" class="form-control form-control-lg" type="number" step="0.01" placeholder="0.00" required>
            <span asp-validation-for="PurchasePrice" class="text-danger small"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label fw-semibold">Selling Price (Rs.)</label>
            <input asp-for="SellingPrice" class="form-control form-control-lg" type="number" step="0.01" placeholder="0.00" required>
            <span asp-validation-for="SellingPrice" class="text-danger small"></span>
        </div>

        <div class="col-md-4">
            <label class="form-label fw-semibold">Initial Stock</label>
            <input asp-for="CurrentStock" class="form-control form-control-lg" type="number" placeholder="0" required>
            <span asp-validation-for="CurrentStock" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">Reorder Level</label>
            <input asp-for="ReorderLevel" class="form-control form-control-lg" type="number" placeholder="10" value="10" required>
            <span asp-validation-for="ReorderLevel" class="text-danger small"></span>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-semibold">Product Image</label>
            <input type="file" name="productImage" class="form-control form-control-lg" accept=".jpg,.jpeg,.png,.webp">
            <small class="text-muted">Max 2MB (JPG, PNG, WebP)</small>
        </div>
    </div>

    <input type="hidden" asp-for="ImageUrl" id="ImageUrl" />
    
    <div class="modal-footer border-0 mt-4 pt-3">
        <button type="button" class="btn btn-lg btn-outline-secondary px-4" onclick="closeCreateModal()">Cancel</button>
        <button type="submit" class="btn btn-lg btn-success px-4">
            <i class="bi bi-check-lg me-2"></i>Save Product
        </button>
    </div>
</form>

<script>
    document.getElementById('createProductForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        var formData = new FormData(this);
        
        fetch('@Url.Action("Create", "Products")', {
            method: 'POST',
            body: formData,
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                notyf.success('Product created successfully!');
                closeCreateModal();
                window.location.reload();
            } else {
                notyf.error(data.message || 'Error creating product');
            }
        })
        .catch(err => {
            notyf.error('Error: ' + err.message);
        });
    });
</script>